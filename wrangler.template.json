{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "honowarden",
	"main": "./src/server/index.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"observability": { "enabled": true },
	"upload_source_maps": true,
	"placement": { "mode": "smart" },
	"assets": {
		"directory": "./dist/client",
		"not_found_handling": "single-page-application"
	},
	"vars": {
		"DOMAIN": "http://localhost:8787"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "honowarden-db",
			"database_id": "placeholder-d1-id",
			"migrations_dir": "drizzle"
		}
	],
	"r2_buckets": [
		{ "binding": "ATTACHMENTS", "bucket_name": "honowarden-attachments" },
		{ "binding": "SENDS", "bucket_name": "honowarden-sends" },
		{ "binding": "ICONS", "bucket_name": "honowarden-icons" }
	],
	"kv_namespaces": [
		{ "binding": "CONFIG", "id": "placeholder-config-kv-id" },
		{ "binding": "RATE_LIMIT", "id": "placeholder-rate-limit-kv-id" }
	],
	"durable_objects": {
		"bindings": [
			{ "name": "USER_HUB", "class_name": "UserNotificationHub" },
			{ "name": "ANON_HUB", "class_name": "AnonymousNotificationHub" }
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["UserNotificationHub", "AnonymousNotificationHub"]
		}
	],
	"queues": {
		"producers": [
			{ "queue": "honowarden-email", "binding": "EMAIL_QUEUE" },
			{ "queue": "honowarden-push", "binding": "PUSH_QUEUE" },
			{ "queue": "honowarden-events", "binding": "EVENT_QUEUE" }
		],
		"consumers": [
			{
				"queue": "honowarden-email",
				"max_batch_size": 10,
				"max_retries": 3,
				"dead_letter_queue": "honowarden-dlq"
			},
			{
				"queue": "honowarden-push",
				"max_batch_size": 50,
				"max_retries": 3
			},
			{
				"queue": "honowarden-events",
				"max_batch_size": 100,
				"max_retries": 2
			}
		]
	},
	"triggers": {
		"crons": [
			"5 * * * *",
			"5 0 * * *",
			"*/1 * * * *",
			"7 * * * *",
			"3 * * * *",
			"10 0 * * *",
			"20 0 * * *"
		]
	}
}
